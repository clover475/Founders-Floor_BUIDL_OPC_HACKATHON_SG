NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
NEXT_PUBLIC_EVENT_SLUG=founders-floor-hackathon
NEXT_PUBLIC_JITSI_DOMAIN=meet.jit.si

# AI Elevator Pitch Coach (server-side only, never expose to client)
# Without a key the coach falls back to a clearly-labeled Demo Mode.
#
# Option A — OpenAI
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.openai.com/v1
# LLM_MODEL=gpt-4o-mini
#
# Option B — DeepSeek
# LLM_API_KEY=sk-...
# LLM_BASE_URL=https://api.deepseek.com/v1
# LLM_MODEL=deepseek-chat
#
# Legacy aliases also accepted: OPENAI_API_KEY, OPENAI_BASE_URL, OPENAI_MODEL
LLM_API_KEY=
LLM_BASE_URL=https://api.deepseek.com/v1
LLM_MODEL=deepseek-chat
